# OneAPI Platform Environment Variables
# Copy this file to .env and fill in your actual values

# =============================================================================
# LLM API Keys
# =============================================================================
# Get your Gemini API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Get your OpenAI API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# Database Configuration (optional, defaults in application.yml)
# =============================================================================
# Uncomment and modify these if you want to override default database settings
# SPRING_DATASOURCE_URL=jdbc:h2:file:./data/oneapi
# SPRING_DATASOURCE_USERNAME=sa
# SPRING_DATASOURCE_PASSWORD=

# =============================================================================
# Application Configuration (optional)
# =============================================================================
# Uncomment to change the default server port
# SERVER_PORT=8088

# =============================================================================
# Security Configuration (optional)
# =============================================================================
# JWT secret key (will be auto-generated if not provided)
# JWT_SECRET=your_secure_jwt_secret_key_here

# =============================================================================
# LLM Provider Selection (optional)
# =============================================================================
# Options: mock, gemini, openai
# ONEAPI_LLM_PROVIDER=mock
