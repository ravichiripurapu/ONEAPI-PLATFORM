<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!-- Test Users -->
    <changeSet id="06-01-insert-john-user" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="app_user"/>
                <sqlCheck expectedResult="0">SELECT COUNT(*) FROM app_user WHERE login = 'john'</sqlCheck>
            </and>
        </preConditions>

        <comment>Insert test user john (password: password123)</comment>

        <insert tableName="app_user">
            <column name="id" value="3"/>
            <column name="login" value="john"/>
            <column name="password_hash" value="$2a$10$dXJ3SW6G7P50lGmMkkmwe.20cQQubK3.HZWzG3YB1tlRy.fqvM/BG"/>
            <column name="first_name" value="John"/>
            <column name="last_name" value="Smith"/>
            <column name="email" value="john@oneapi.io"/>
            <column name="activated" valueBoolean="true"/>
            <column name="lang_key" value="en"/>
            <column name="created_by" value="system"/>
            <column name="created_date" valueDate="2024-01-01T00:00:00"/>
        </insert>

        <insert tableName="user_authority">
            <column name="user_id" value="3"/>
            <column name="authority_name" value="ROLE_USER"/>
        </insert>
    </changeSet>

    <changeSet id="06-02-insert-jane-user" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="app_user"/>
                <sqlCheck expectedResult="0">SELECT COUNT(*) FROM app_user WHERE login = 'jane'</sqlCheck>
            </and>
        </preConditions>

        <comment>Insert test user jane (password: password123)</comment>

        <insert tableName="app_user">
            <column name="id" value="4"/>
            <column name="login" value="jane"/>
            <column name="password_hash" value="$2a$10$dXJ3SW6G7P50lGmMkkmwe.20cQQubK3.HZWzG3YB1tlRy.fqvM/BG"/>
            <column name="first_name" value="Jane"/>
            <column name="last_name" value="Doe"/>
            <column name="email" value="jane@oneapi.io"/>
            <column name="activated" valueBoolean="true"/>
            <column name="lang_key" value="en"/>
            <column name="created_by" value="system"/>
            <column name="created_date" valueDate="2024-01-01T00:00:00"/>
        </insert>

        <insert tableName="user_authority">
            <column name="user_id" value="4"/>
            <column name="authority_name" value="ROLE_USER"/>
        </insert>
    </changeSet>

    <!-- Test Datasource -->
    <changeSet id="06-03-insert-test-datasource" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="datasources"/>
                <sqlCheck expectedResult="0">SELECT COUNT(*) FROM datasources WHERE name = 'Local H2 Database (Embedded)'</sqlCheck>
            </and>
        </preConditions>

        <comment>Insert test datasource pointing to embedded H2</comment>

        <insert tableName="datasources">
            <column name="id" value="1"/>
            <column name="name" value="Local H2 Database (Embedded)"/>
            <column name="type" value="H2"/>
            <column name="host" value=""/>
            <column name="port" value="0"/>
            <column name="database" value="jdbc:h2:file:./data/oneapi;AUTO_SERVER=TRUE"/>
            <column name="username" value="sa"/>
            <column name="password" value=""/>
            <column name="created_at" valueDate="2024-01-01T00:00:00"/>
            <column name="updated_at" valueDate="2024-01-01T00:00:00"/>
            <column name="active" valueBoolean="true"/>
        </insert>
    </changeSet>

    <!-- Test Catalogs -->
    <changeSet id="06-04-insert-sales-catalog" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="catalog"/>
                <sqlCheck expectedResult="0">SELECT COUNT(*) FROM catalog WHERE name = 'Sales Reports'</sqlCheck>
            </and>
        </preConditions>

        <comment>Insert Sales Reports catalog</comment>

        <insert tableName="catalog">
            <column name="id" value="1"/>
            <column name="name" value="Sales Reports"/>
            <column name="description" value="Sales and revenue reports catalog"/>
            <column name="created_by" value="admin"/>
            <column name="created_date" valueDate="2024-01-01T00:00:00"/>
            <column name="last_modified_by" value="admin"/>
            <column name="last_modified_date" valueDate="2024-01-01T00:00:00"/>
        </insert>
    </changeSet>

    <changeSet id="06-05-insert-hr-catalog" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="catalog"/>
                <sqlCheck expectedResult="0">SELECT COUNT(*) FROM catalog WHERE name = 'HR Reports'</sqlCheck>
            </and>
        </preConditions>

        <comment>Insert HR Reports catalog</comment>

        <insert tableName="catalog">
            <column name="id" value="2"/>
            <column name="name" value="HR Reports"/>
            <column name="description" value="Human resources and employee reports catalog"/>
            <column name="created_by" value="admin"/>
            <column name="created_date" valueDate="2024-01-01T00:00:00"/>
            <column name="last_modified_by" value="admin"/>
            <column name="last_modified_date" valueDate="2024-01-01T00:00:00"/>
        </insert>
    </changeSet>

</databaseChangeLog>
