<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!-- Create user_preferences table (or rename if old table exists) -->
    <changeSet id="07-01-create-user-preferences" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="user_preferences"/>
            </not>
        </preConditions>
        <!-- Check if old table exists to rename, otherwise create new table -->
        <createTable tableName="user_preferences">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="page_size" type="INTEGER"/>
            <column name="ttl_minutes" type="INTEGER"/>
            <column name="max_concurrent_sessions" type="INTEGER"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
        <addUniqueConstraint tableName="user_preferences" columnNames="user_id" constraintName="uk_user_preferences_user_id"/>
    </changeSet>

    <!-- Rename old table if it exists (for backwards compatibility) -->
    <changeSet id="07-01a-rename-user-query-preferences" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="user_query_preferences"/>
        </preConditions>
        <dropTable tableName="user_preferences"/>
        <renameTable oldTableName="user_query_preferences" newTableName="user_preferences"/>
    </changeSet>

    <!-- Drop unused permission tables (if they exist) -->
    <changeSet id="07-02-drop-database-permission-table" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="database_permission"/>
        </preConditions>
        <dropTable tableName="database_permission" cascadeConstraints="true"/>
    </changeSet>

    <changeSet id="07-03-drop-table-permission-table" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="table_permission"/>
        </preConditions>
        <dropTable tableName="table_permission" cascadeConstraints="true"/>
    </changeSet>

    <changeSet id="07-04-drop-column-permission-table" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="column_permission"/>
        </preConditions>
        <dropTable tableName="column_permission" cascadeConstraints="true"/>
    </changeSet>

    <!-- Drop api_client_scopes table (if exists) -->
    <changeSet id="07-05-drop-api-client-scopes-table" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="api_client_scopes"/>
        </preConditions>
        <dropTable tableName="api_client_scopes" cascadeConstraints="true"/>
    </changeSet>

    <!-- Drop api_clients table (if exists) -->
    <changeSet id="07-06-drop-api-clients-table" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="api_clients"/>
        </preConditions>
        <dropTable tableName="api_clients" cascadeConstraints="true"/>
    </changeSet>

    <!-- Drop schema_versions table (if exists) -->
    <changeSet id="07-07-drop-schema-versions-table" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="schema_versions"/>
        </preConditions>
        <dropTable tableName="schema_versions" cascadeConstraints="true"/>
    </changeSet>

    <!-- Drop permissions table (if exists) -->
    <changeSet id="07-08-drop-permissions-table" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="permissions"/>
        </preConditions>
        <dropTable tableName="permissions" cascadeConstraints="true"/>
    </changeSet>

    <!-- Drop user_roles table (if exists) -->
    <changeSet id="07-09-drop-user-roles-table" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="user_roles"/>
        </preConditions>
        <dropTable tableName="user_roles" cascadeConstraints="true"/>
    </changeSet>

    <!-- Drop roles table (if exists) -->
    <changeSet id="07-10-drop-roles-table" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="roles"/>
        </preConditions>
        <dropTable tableName="roles" cascadeConstraints="true"/>
    </changeSet>

</databaseChangeLog>
