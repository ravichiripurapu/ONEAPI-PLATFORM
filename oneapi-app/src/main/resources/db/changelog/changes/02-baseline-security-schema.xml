<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!-- Create sequence for ID generation -->
    <changeSet id="03-create-sequence" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <not>
                <sequenceExists sequenceName="sequence_generator"/>
            </not>
        </preConditions>
        <createSequence sequenceName="sequence_generator" startValue="1050" incrementBy="50"/>
    </changeSet>

    <!-- Create User table -->
    <changeSet id="03-create-user-table" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="app_user"/>
            </not>
        </preConditions>
        <createTable tableName="app_user">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="login" type="VARCHAR(50)">
                <constraints unique="true" nullable="false" uniqueConstraintName="ux_user_login"/>
            </column>
            <column name="password_hash" type="VARCHAR(60)"/>
            <column name="first_name" type="VARCHAR(50)"/>
            <column name="last_name" type="VARCHAR(50)"/>
            <column name="email" type="VARCHAR(191)">
                <constraints unique="true" uniqueConstraintName="ux_user_email"/>
            </column>
            <column name="image_url" type="VARCHAR(256)"/>
            <column name="activated" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false" />
            </column>
            <column name="lang_key" type="VARCHAR(10)"/>
            <column name="activation_key" type="VARCHAR(20)"/>
            <column name="reset_key" type="VARCHAR(20)"/>
            <column name="created_by" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="created_date" type="TIMESTAMP"/>
            <column name="reset_date" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(50)"/>
            <column name="last_modified_date" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <!-- Create Authority table -->
    <changeSet id="03-create-authority-table" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="app_authority"/>
            </not>
        </preConditions>
        <createTable tableName="app_authority">
            <column name="name" type="VARCHAR(50)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Create User-Authority join table -->
    <changeSet id="03-create-user-authority-table" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="user_authority"/>
            </not>
        </preConditions>
        <createTable tableName="user_authority">
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="authority_name" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey columnNames="user_id, authority_name" tableName="user_authority"/>

        <addForeignKeyConstraint baseColumnNames="authority_name"
                                 baseTableName="user_authority"
                                 constraintName="fk_authority_name"
                                 referencedColumnNames="name"
                                 referencedTableName="app_authority"/>

        <addForeignKeyConstraint baseColumnNames="user_id"
                                 baseTableName="user_authority"
                                 constraintName="fk_user_id"
                                 referencedColumnNames="id"
                                 referencedTableName="app_user"/>
    </changeSet>


    <!-- Insert default authorities -->
    <changeSet id="03-insert-authorities" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM app_authority WHERE name = 'ROLE_ADMIN'</sqlCheck>
        </preConditions>
        <insert tableName="app_authority">
            <column name="name" value="ROLE_ADMIN"/>
        </insert>
        <insert tableName="app_authority">
            <column name="name" value="ROLE_USER"/>
        </insert>
        <insert tableName="app_authority">
            <column name="name" value="ROLE_DEVELOPER"/>
        </insert>
    </changeSet>

    <!-- Insert default admin user (password: admin123) -->
    <changeSet id="03-insert-admin-user" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM app_user WHERE login = 'admin'</sqlCheck>
        </preConditions>
        <insert tableName="app_user">
            <column name="id" valueNumeric="1"/>
            <column name="login" value="admin"/>
            <!-- BCrypt hash for "admin123" -->
            <column name="password_hash" value="$2a$10$S/1CSuGkzTTpuXeawUpcYOpkRG6778BkpSAn/dKN3OKt7QgEbPdyW"/>
            <column name="first_name" value="Admin"/>
            <column name="last_name" value="User"/>
            <column name="email" value="admin@oneapi.io"/>
            <column name="activated" valueBoolean="true"/>
            <column name="lang_key" value="en"/>
            <column name="created_by" value="system"/>
            <column name="created_date" valueDate="now()"/>
        </insert>

        <insert tableName="user_authority">
            <column name="user_id" valueNumeric="1"/>
            <column name="authority_name" value="ROLE_ADMIN"/>
        </insert>
        <insert tableName="user_authority">
            <column name="user_id" valueNumeric="1"/>
            <column name="authority_name" value="ROLE_USER"/>
        </insert>
    </changeSet>

    <!-- Insert default developer user (password: dev123) -->
    <changeSet id="03-insert-developer-user" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM app_user WHERE login = 'developer'</sqlCheck>
        </preConditions>
        <insert tableName="app_user">
            <column name="id" valueNumeric="2"/>
            <column name="login" value="developer"/>
            <!-- BCrypt hash for "dev123" -->
            <column name="password_hash" value="$2a$10$.sQmq0bHkxnJ0knbd8W26eEl1OvZkUPjWKvvcl5nrAIufOlKSMRvq"/>
            <column name="first_name" value="Developer"/>
            <column name="last_name" value="User"/>
            <column name="email" value="developer@oneapi.io"/>
            <column name="activated" valueBoolean="true"/>
            <column name="lang_key" value="en"/>
            <column name="created_by" value="system"/>
            <column name="created_date" valueDate="now()"/>
        </insert>

        <insert tableName="user_authority">
            <column name="user_id" valueNumeric="2"/>
            <column name="authority_name" value="ROLE_DEVELOPER"/>
        </insert>
        <insert tableName="user_authority">
            <column name="user_id" valueNumeric="2"/>
            <column name="authority_name" value="ROLE_USER"/>
        </insert>
    </changeSet>

</databaseChangeLog>
