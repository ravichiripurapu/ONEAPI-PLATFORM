<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <!-- Schema Metadata Table -->
    <changeSet id="05-create-schema-metadata" author="oneapi">
        <createTable tableName="schema_metadata">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="connection_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="catalog_name" type="VARCHAR(255)"/>
            <column name="schema_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="table_count" type="INTEGER" defaultValueNumeric="0"/>
            <column name="view_count" type="INTEGER" defaultValueNumeric="0"/>
            <column name="discovered_at" type="TIMESTAMP"/>
            <column name="last_synced_at" type="TIMESTAMP"/>
            <column name="sdk_catalog_json" type="CLOB"/>
            <column name="created_date" type="TIMESTAMP"/>
        </createTable>

        <!-- Foreign key to database_connections -->
        <addForeignKeyConstraint
                baseTableName="schema_metadata"
                baseColumnNames="connection_id"
                constraintName="fk_schema_connection"
                referencedTableName="database_connections"
                referencedColumnNames="id"
                onDelete="CASCADE"/>

        <!-- Indexes for performance -->
        <createIndex tableName="schema_metadata" indexName="idx_schema_connection">
            <column name="connection_id"/>
        </createIndex>

        <createIndex tableName="schema_metadata" indexName="idx_schema_name">
            <column name="schema_name"/>
        </createIndex>
    </changeSet>

    <!-- Table Metadata Table -->
    <changeSet id="05-create-table-metadata" author="oneapi">
        <createTable tableName="table_metadata">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="schema_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="table_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="table_type" type="VARCHAR(50)"/>
            <column name="table_comment" type="CLOB"/>
            <column name="estimated_row_count" type="BIGINT"/>
            <column name="size_in_bytes" type="BIGINT"/>
            <column name="discovered_at" type="TIMESTAMP"/>
            <column name="last_synced_at" type="TIMESTAMP"/>
            <column name="sdk_entity_json" type="CLOB"/>
            <column name="created_date" type="TIMESTAMP"/>
        </createTable>

        <!-- Foreign key to schema_metadata -->
        <addForeignKeyConstraint
                baseTableName="table_metadata"
                baseColumnNames="schema_id"
                constraintName="fk_table_schema"
                referencedTableName="schema_metadata"
                referencedColumnNames="id"
                onDelete="CASCADE"/>

        <!-- Indexes for performance -->
        <createIndex tableName="table_metadata" indexName="idx_table_schema">
            <column name="schema_id"/>
        </createIndex>

        <createIndex tableName="table_metadata" indexName="idx_table_name">
            <column name="table_name"/>
        </createIndex>
    </changeSet>

    <!-- Column Metadata Table -->
    <changeSet id="05-create-column-metadata" author="oneapi">
        <createTable tableName="column_metadata">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="table_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="column_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="data_type" type="VARCHAR(100)"/>
            <column name="jdbc_type" type="VARCHAR(100)"/>
            <column name="column_size" type="INTEGER"/>
            <column name="decimal_digits" type="INTEGER"/>
            <column name="nullable" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="default_value" type="VARCHAR(255)"/>
            <column name="column_comment" type="CLOB"/>
            <column name="is_primary_key" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="is_foreign_key" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="is_unique" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="is_indexed" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="is_auto_increment" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="ordinal_position" type="INTEGER"/>
            <column name="discovered_at" type="TIMESTAMP"/>
            <column name="json_schema_fragment" type="CLOB"/>
            <column name="created_date" type="TIMESTAMP"/>
        </createTable>

        <!-- Foreign key to table_metadata -->
        <addForeignKeyConstraint
                baseTableName="column_metadata"
                baseColumnNames="table_id"
                constraintName="fk_column_table"
                referencedTableName="table_metadata"
                referencedColumnNames="id"
                onDelete="CASCADE"/>

        <!-- Indexes for performance -->
        <createIndex tableName="column_metadata" indexName="idx_column_table">
            <column name="table_id"/>
        </createIndex>

        <createIndex tableName="column_metadata" indexName="idx_column_name">
            <column name="column_name"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
