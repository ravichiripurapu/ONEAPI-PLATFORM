<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="07-add-connection-to-catalog" author="oneapi">
        <comment>Add connection_id foreign key to catalog table to link catalogs to datasources</comment>

        <!-- Add connection_id column to catalog table -->
        <addColumn tableName="catalog">
            <column name="connection_id" type="BIGINT">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <!-- Add foreign key constraint -->
        <addForeignKeyConstraint
                baseTableName="catalog"
                baseColumnNames="connection_id"
                constraintName="fk_catalog_connection"
                referencedTableName="database_connections"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
