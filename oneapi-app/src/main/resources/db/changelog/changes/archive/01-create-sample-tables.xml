<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!-- Create SAMPLE_DB schema for demo/testing purposes -->
    <changeSet id="01-create-sample-employees-table" author="oneapi">
        <createTable tableName="sample_employees">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="employee_id" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="first_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="phone" type="VARCHAR(20)"/>
            <column name="department" type="VARCHAR(100)"/>
            <column name="position" type="VARCHAR(100)"/>
            <column name="salary" type="DECIMAL(15,2)"/>
            <column name="hire_date" type="DATE"/>
            <column name="manager_id" type="BIGINT"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createIndex tableName="sample_employees" indexName="idx_sample_employees_department">
            <column name="department"/>
        </createIndex>
        <createIndex tableName="sample_employees" indexName="idx_sample_employees_email">
            <column name="email"/>
        </createIndex>
    </changeSet>

    <changeSet id="02-create-sample-customers-table" author="oneapi">
        <createTable tableName="sample_customers">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="customer_id" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="company_name" type="VARCHAR(200)"/>
            <column name="contact_name" type="VARCHAR(150)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="phone" type="VARCHAR(20)"/>
            <column name="address" type="VARCHAR(500)"/>
            <column name="city" type="VARCHAR(100)"/>
            <column name="state" type="VARCHAR(100)"/>
            <column name="country" type="VARCHAR(100)"/>
            <column name="postal_code" type="VARCHAR(20)"/>
            <column name="credit_limit" type="DECIMAL(15,2)"/>
            <column name="customer_since" type="DATE"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createIndex tableName="sample_customers" indexName="idx_sample_customers_email">
            <column name="email"/>
        </createIndex>
        <createIndex tableName="sample_customers" indexName="idx_sample_customers_country">
            <column name="country"/>
        </createIndex>
    </changeSet>

    <changeSet id="03-create-sample-products-table" author="oneapi">
        <createTable tableName="sample_products">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="product_id" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="product_name" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="category" type="VARCHAR(100)"/>
            <column name="description" type="TEXT"/>
            <column name="unit_price" type="DECIMAL(15,2)">
                <constraints nullable="false"/>
            </column>
            <column name="stock_quantity" type="INT" defaultValueNumeric="0"/>
            <column name="reorder_level" type="INT" defaultValueNumeric="10"/>
            <column name="supplier" type="VARCHAR(200)"/>
            <column name="is_available" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createIndex tableName="sample_products" indexName="idx_sample_products_category">
            <column name="category"/>
        </createIndex>
        <createIndex tableName="sample_products" indexName="idx_sample_products_name">
            <column name="product_name"/>
        </createIndex>
    </changeSet>

    <changeSet id="04-create-sample-orders-table" author="oneapi">
        <createTable tableName="sample_orders">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_id" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="customer_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_orders_customer"
                             references="sample_customers(id)"/>
            </column>
            <column name="order_date" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="ship_date" type="TIMESTAMP"/>
            <column name="required_date" type="DATE"/>
            <column name="status" type="VARCHAR(50)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="total_amount" type="DECIMAL(15,2)" defaultValueNumeric="0"/>
            <column name="tax_amount" type="DECIMAL(15,2)" defaultValueNumeric="0"/>
            <column name="shipping_address" type="VARCHAR(500)"/>
            <column name="shipping_city" type="VARCHAR(100)"/>
            <column name="shipping_country" type="VARCHAR(100)"/>
            <column name="payment_method" type="VARCHAR(50)"/>
            <column name="notes" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createIndex tableName="sample_orders" indexName="idx_sample_orders_customer">
            <column name="customer_id"/>
        </createIndex>
        <createIndex tableName="sample_orders" indexName="idx_sample_orders_status">
            <column name="status"/>
        </createIndex>
        <createIndex tableName="sample_orders" indexName="idx_sample_orders_date">
            <column name="order_date"/>
        </createIndex>
    </changeSet>

    <changeSet id="05-create-sample-order-items-table" author="oneapi">
        <createTable tableName="sample_order_items">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_order_items_order"
                             references="sample_orders(id)"/>
            </column>
            <column name="product_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_order_items_product"
                             references="sample_products(id)"/>
            </column>
            <column name="quantity" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="unit_price" type="DECIMAL(15,2)">
                <constraints nullable="false"/>
            </column>
            <column name="discount" type="DECIMAL(5,2)" defaultValueNumeric="0"/>
            <column name="line_total" type="DECIMAL(15,2)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createIndex tableName="sample_order_items" indexName="idx_sample_order_items_order">
            <column name="order_id"/>
        </createIndex>
        <createIndex tableName="sample_order_items" indexName="idx_sample_order_items_product">
            <column name="product_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
