<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Insert default admin user -->
    <changeSet id="10-insert-admin-user" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM app_user WHERE login = 'admin'</sqlCheck>
        </preConditions>
        <insert tableName="app_user">
            <column name="id" valueNumeric="1"/>
            <column name="login" value="admin"/>
            <!-- BCrypt hash for password: admin -->
            <column name="password_hash" value="$2a$10$gSAhZrxMllrbgj/kkK9UceBPpChGWJA7SYIb1Mqo.n5aNLq1/oRrC"/>
            <column name="first_name" value="Administrator"/>
            <column name="last_name" value="User"/>
            <column name="email" value="admin@localhost"/>
            <column name="activated" valueBoolean="true"/>
            <column name="lang_key" value="en"/>
            <column name="created_by" value="system"/>
            <column name="created_date" valueDate="now()"/>
            <column name="last_modified_by" value="system"/>
            <column name="last_modified_date" valueDate="now()"/>
        </insert>
    </changeSet>

    <!-- Insert default ADMIN role -->
    <changeSet id="10-insert-admin-role" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM role WHERE name = 'ROLE_ADMIN'</sqlCheck>
        </preConditions>
        <insert tableName="role">
            <column name="id" valueNumeric="1"/>
            <column name="name" value="ROLE_ADMIN"/>
            <column name="description" value="Administrator role with full system access"/>
            <column name="created_by" value="system"/>
            <column name="created_at" valueDate="now()"/>
            <column name="updated_by" value="system"/>
            <column name="updated_at" valueDate="now()"/>
        </insert>
    </changeSet>

    <!-- Assign ADMIN role to admin user -->
    <changeSet id="10-assign-admin-role" author="oneapi">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM user_role WHERE user_id = 1 AND role_id = 1</sqlCheck>
        </preConditions>
        <insert tableName="user_role">
            <column name="id" valueNumeric="1"/>
            <column name="user_id" valueNumeric="1"/>
            <column name="role_id" valueNumeric="1"/>
            <column name="assigned_by" value="system"/>
            <column name="assigned_at" valueDate="now()"/>
        </insert>
    </changeSet>

</databaseChangeLog>
