{
  "info": {
    "name": "OneAPI - Sample Data Management",
    "description": "Collection for managing sample database tables and test data",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8090",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Sample Data Management",
      "item": [
        {
          "name": "Get Sample Data Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sample-data/info",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sample-data", "info"]
            },
            "description": "Get information about available sample tables and data"
          },
          "response": []
        },
        {
          "name": "Regenerate Sample Data",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sample-data/regenerate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sample-data", "regenerate"]
            },
            "description": "Clear existing sample data and generate fresh data using JavaFaker"
          },
          "response": []
        },
        {
          "name": "Clear Sample Data",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sample-data/clear",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sample-data", "clear"]
            },
            "description": "Remove all records from sample tables"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Database Connections",
      "item": [
        {
          "name": "Create H2 Sample DB Connection",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('connectionId', jsonData.id);",
                  "    pm.test('Connection created successfully', function () {",
                  "        pm.expect(jsonData.name).to.eql('Sample H2 DB');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sample H2 DB\",\n  \"type\": \"H2\",\n  \"host\": \"localhost\",\n  \"port\": 9092,\n  \"database\": \"./data/oneapi-admin\",\n  \"username\": \"sa\",\n  \"password\": \"\",\n  \"userId\": \"testuser\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/connections",
              "host": ["{{baseUrl}}"],
              "path": ["api", "connections"]
            },
            "description": "Create a connection to the H2 sample database"
          },
          "response": []
        },
        {
          "name": "List All Connections",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/connections?userId=testuser",
              "host": ["{{baseUrl}}"],
              "path": ["api", "connections"],
              "query": [
                {
                  "key": "userId",
                  "value": "testuser"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Sample Data Queries",
      "item": [
        {
          "name": "Query Employees",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"connectionId\": \"{{connectionId}}\",\n  \"sql\": \"SELECT * FROM sample_employees LIMIT 10\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/query/execute",
              "host": ["{{baseUrl}}"],
              "path": ["api", "query", "execute"]
            },
            "description": "Query sample employees table"
          },
          "response": []
        },
        {
          "name": "Query Customers",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"connectionId\": \"{{connectionId}}\",\n  \"sql\": \"SELECT * FROM sample_customers WHERE country = 'USA' LIMIT 10\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/query/execute",
              "host": ["{{baseUrl}}"],
              "path": ["api", "query", "execute"]
            }
          },
          "response": []
        },
        {
          "name": "Query Products by Category",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"connectionId\": \"{{connectionId}}\",\n  \"sql\": \"SELECT category, COUNT(*) as product_count, AVG(unit_price) as avg_price FROM sample_products GROUP BY category\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/query/execute",
              "host": ["{{baseUrl}}"],
              "path": ["api", "query", "execute"]
            }
          },
          "response": []
        },
        {
          "name": "Query Orders with Customer Details",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"connectionId\": \"{{connectionId}}\",\n  \"sql\": \"SELECT o.order_id, o.order_date, o.status, o.total_amount, c.company_name, c.contact_name FROM sample_orders o JOIN sample_customers c ON o.customer_id = c.id ORDER BY o.order_date DESC LIMIT 20\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/query/execute",
              "host": ["{{baseUrl}}"],
              "path": ["api", "query", "execute"]
            }
          },
          "response": []
        },
        {
          "name": "Query Top Selling Products",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"connectionId\": \"{{connectionId}}\",\n  \"sql\": \"SELECT p.product_name, p.category, SUM(oi.quantity) as units_sold, SUM(oi.line_total) as revenue FROM sample_products p JOIN sample_order_items oi ON p.id = oi.product_id GROUP BY p.id, p.product_name, p.category ORDER BY revenue DESC LIMIT 10\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/query/execute",
              "host": ["{{baseUrl}}"],
              "path": ["api", "query", "execute"]
            }
          },
          "response": []
        },
        {
          "name": "Query Employee Hierarchy",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"connectionId\": \"{{connectionId}}\",\n  \"sql\": \"SELECT e.employee_id, e.first_name || ' ' || e.last_name as employee_name, e.position, e.department, m.first_name || ' ' || m.last_name as manager_name FROM sample_employees e LEFT JOIN sample_employees m ON e.manager_id = m.id WHERE e.is_active = true LIMIT 20\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/query/execute",
              "host": ["{{baseUrl}}"],
              "path": ["api", "query", "execute"]
            }
          },
          "response": []
        },
        {
          "name": "Query Department Summary",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"connectionId\": \"{{connectionId}}\",\n  \"sql\": \"SELECT department, COUNT(*) as employee_count, AVG(salary) as avg_salary, MIN(salary) as min_salary, MAX(salary) as max_salary FROM sample_employees WHERE is_active = true GROUP BY department ORDER BY employee_count DESC\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/query/execute",
              "host": ["{{baseUrl}}"],
              "path": ["api", "query", "execute"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
