            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.id_token) {",
                  "    pm.collectionVariables.set('jwt_token', jsonData.id_token);",
                  "    console.log('JWT Token saved:', jsonData.id_token);",
                  "}"
                ],
                "type": "text/javascript"
