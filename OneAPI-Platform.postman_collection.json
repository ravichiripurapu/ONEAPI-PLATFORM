{
	"info": {
		"_postman_id": "oneapi-platform-2026",
		"name": "OneAPI Platform - Complete API Collection",
		"description": "Comprehensive API collection for OneAPI Platform running on port 8088",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{jwt_token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8088",
			"type": "string"
		},
		{
			"key": "jwt_token",
			"value": "",
			"type": "string"
		},
